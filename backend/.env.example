# Set true to force mock STT (also used when DEEPGRAM_API_KEY is empty)
MOCK_TRANSCRIPTION=false
MOCK_TRANSCRIPT_EVERY_N_CHUNKS=8
MOCK_BATTLECARD_ON_CONNECT=false

LLM_MODEL=gpt-4o-mini

# Hugging Face Sentence Transformers model id (local embeddings for Chroma; no API key). After changing this, delete backend/chroma_db/ and restart.
EMBEDDING_MODEL=all-MiniLM-L6-v2

MIN_RELEVANCE_SCORE=-1.0
# Longer interval + gap between mic/screen Groq calls to reduce 429 rate limits
GROQ_TRANSCRIBE_INTERVAL_SECONDS=12
GROQ_MIN_GAP_BETWEEN_CALLS_SECONDS=1.5
MAX_L2_DISTANCE=1.85
BATTLECARD_COOLDOWN_SECONDS=45

CORS_ORIGINS=*
